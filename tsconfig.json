{
  "compilerOptions": {
    "rootDir": "./",
    "outDir": "./dist",
    "module": "Node16",
    "moduleResolution": "Node16",
    "target": "ES2022",
    "esModuleInterop": true,
    "strict": true,
    "sourceMap": true,
    "skipLibCheck": true,
    "types": ["node"]
  },
  "include": ["src" , "prisma/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}