// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  
}

// ============================================
// 1. ESCOLA (Root Tenant)
// ============================================
model Escola {
  id       String  @id @default(uuid())
  nome     String  @db.VarChar(150)
  cnpj     String  @unique @db.VarChar(14) // Armazenar apenas números
  telefone String? @db.VarChar(15)
  email    String? @db.VarChar(100)
  logo     String? @db.VarChar(255) // URL da logo

  // Configurações padrão (Semente financeira)
  mensalidadePadrao Decimal @default(0) @db.Decimal(10, 2)
  diaVencimento     Int     @default(10)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relacionamentos - Padronização de nomes
  usuarios             Usuario[]
  alunos               Aluno[]
  funcionarios         Funcionario[]
  turmas               Turma[]
  disciplinas          Disciplina[]
  transacoes           Transacao[]
  atividadesExtra      AtividadeExtra[]
  comunicados          Comunicado[]
  matriculas           Matricula[]
  rematriculas         Rematricula[]
  ocorrencias          Ocorrencia[]
  eventos              Evento[]
  logAuditorias        LogAuditoria[]
  lancamentos          Lancamento[]
  frequencias          Frequencia[]
  gradeHorarias        GradeHoraria[]
  cronogramaProva      CronogramaProva[]
  contratos            Contrato[] // Corrigido de contratoes
  boletos              Boletos[]
  responsaveis         Responsavel[] // Corrigido de responsavels
  enderecos            Endereco[]
  alunoAtividadeExtras AlunoAtividadeExtra[]
  pagamentoSalarios    PagamentoSalario[]
  turmaProfessors      TurmaProfessor[]

  @@map("escolas")
}

// ============================================
// 2. USUÁRIO (Autenticação)
// ============================================
model Usuario {
  id    String      @id @default(uuid())
  email String      @unique @db.VarChar(150)
  senha String      @db.VarChar(255) // Hash bcrypt
  nome  String      @db.VarChar(100)
  role  RoleUsuario @default(SECRETARIA)

  escolaId String
  escola   Escola @relation(fields: [escolaId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relacionamentos
  histories History[]

  @@index([escolaId])
  @@map("usuarios")
}

enum RoleUsuario {
  ADMIN // Dono da escola
  SECRETARIA // Acesso total administrativo
  PROFESSOR // Acesso a turmas e notas
  RESPONSAVEL // Acesso apenas responsavel
}

// ============================================
// 3. ENDEREÇO (Isolado por Tenant)
// ============================================
model Endereco {
  id          String  @id @default(uuid())
  rua         String  @db.VarChar(150)
  numero      String  @db.VarChar(20)
  complemento String? @db.VarChar(100)
  bairro      String  @db.VarChar(100)
  cidade      String  @db.VarChar(100)
  estado      String  @db.Char(2)
  cep         String  @db.VarChar(8) // Armazenar apenas os números

  // --- Multi-tenancy Absoluto ---
  escolaId String
  escola   Escola @relation(fields: [escolaId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relacionamentos
  alunos       Aluno[]
  responsaveis Responsavel[]
  funcionarios Funcionario[]

  @@index([escolaId]) // Index vital para performance das buscas
  @@map("enderecos")
}

// ============================================
// 4. ALUNO
// ============================================
model Aluno {
  id             String    @id @default(uuid())
  nome           String    @db.VarChar(100)
  cpf            String?   @db.VarChar(11)
  dataNascimento DateTime? @db.Date
  naturalidade   String?   @db.VarChar(50)
  genero         String?   @db.VarChar(20)
  foto           String?   @db.VarChar(255) // URL da foto do aluno

  // Dados de matrícula
  numeroMatricula String   @db.VarChar(7) // Ex: "26.0001"
  dataMatricula   DateTime @default(now())

  // Campos de Saúde (Etapa 1)
  numeroSus  String? @db.VarChar(15)
  planoSaude Boolean @default(false)
  hospital   String? @db.VarChar(50)
  alergias   String? @db.VarChar(100)

  // Relacionamentos
  escolaId String
  escola   Escola @relation(fields: [escolaId], references: [id], onDelete: Cascade)

  enderecoId String?
  endereco   Endereco? @relation(fields: [enderecoId], references: [id], onDelete: SetNull)

  turmaId String? // Aluno em APENAS 1 turma
  turma   Turma?  @relation(fields: [turmaId], references: [id], onDelete: SetNull)

  // Soft delete
  deletedAt DateTime? @db.Date

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relacionamentos
  responsaveis    Responsavel[]
  contrato        Contrato?
  boletos         Boletos[]
  notas           Nota[]
  atividadesExtra AlunoAtividadeExtra[]
  frequencias     Frequencia[]
  comunicados     Comunicado[]
  matricula       Matricula?
  rematriculas    Rematricula[]
  ocorrencias     Ocorrencia[]
  lancamentos     Lancamento[]

  @@unique([cpf, escolaId]) // Unicidade restrita a cada escola
  @@unique([numeroMatricula, escolaId])
  @@index([escolaId])
  @@index([turmaId])
  @@index([deletedAt])
  @@map("alunos")
}

// ============================================
// 5. RESPONSÁVEL (Família e Financeiro)
// ============================================
model Responsavel {
  id             String    @id @default(uuid()) // UUID v4 Obrigatório
  nome           String    @db.VarChar(100)
  cpf            String?   @db.VarChar(11) // Essencial para emissão de boletos/contratos
  rg             String?   @db.VarChar(20)
  dataNascimento DateTime? @db.Date
  telefone1      String?   @db.VarChar(15)
  telefone2      String?   @db.VarChar(15) // Segundo telefone solicitado
  email          String?   @db.VarChar(70)

  // --- Regras de Negócio ---
  tipo                    TipoResponsavel
  isResponsavelFinanceiro Boolean         @default(false)

  // --- Relacionamentos de Identidade ---
  alunoId String
  aluno   Aluno  @relation(fields: [alunoId], references: [id], onDelete: Cascade)

  // --- Multi-tenancy Absoluto ---
  escolaId String
  escola   Escola @relation(fields: [escolaId], references: [id], onDelete: Cascade)

  // --- Localização Reutilizável ---
  enderecoId String?
  endereco   Endereco? @relation(fields: [enderecoId], references: [id], onDelete: SetNull)

  // --- Motor Financeiro e Comunicação ---
  contratos   Contrato[] // Relação 1:N com Contratos (onde ele é o pagador)
  lancamentos Lancamento[] // Relação com parcelas/boletos
  comunicados Comunicado[]

  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  transacaos Transacao[]

  @@unique([cpf, alunoId, escolaId])
  @@index([alunoId])
  @@index([escolaId])
  @@index([cpf]) // Indexado para buscas rápidas de histórico familiar
  @@index([isResponsavelFinanceiro])
  @@map("responsaveis")
}

enum TipoResponsavel {
  PAI
  MAE
  AVO
  TUTOR
  OUTRO
}

// ============================================
// 6. CONTRATO (Condições Financeiras Evoluídas)
// ============================================
model Contrato {
  id String @id @default(uuid())

  // --- Composição Financeira da Matrícula (Taxa Única) ---
  valorMatricula    Decimal @default(0) @db.Decimal(10, 2)
  descontoMatricula Decimal @default(0) @db.Decimal(10, 2)

  // --- Composição da Mensalidade (Recorrente) ---
  valorMensalidadeBase Decimal @default(0) @db.Decimal(10, 2)
  descontoMensalidade  Decimal @default(0) @db.Decimal(10, 2)

  diaVencimento      Int       @default(10)
  quantidadeParcelas Int       @default(12)
  dataInicio         DateTime  @default(now())
  dataFim            DateTime? @db.Date

  status StatusContrato @default(ATIVO)
  ativo  Boolean        @default(true)

  // --- Relacionamentos ---
  alunoId String @unique
  aluno   Aluno  @relation(fields: [alunoId], references: [id], onDelete: Cascade)

  responsavelFinanceiroId String
  responsavelFinanceiro   Responsavel @relation(fields: [responsavelFinanceiroId], references: [id], onDelete: Restrict)

  escolaId String
  escola   Escola @relation(fields: [escolaId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  matriculas Matricula[]
  transacoes Transacao[]

  @@index([escolaId])
  @@index([alunoId])
  @@map("contratos")
}

enum StatusContrato {
  ATIVO
  SUSPENSO
  CANCELADO
  FINALIZADO
}

// ============================================
// 7. ATIVIDADE EXTRA
// ============================================
model AtividadeExtra {
  id        String  @id @default(uuid())
  nome      String  @db.VarChar(100)
  descricao String? @db.VarChar(100)
  valor     Decimal @db.Decimal(10, 2)

  diaAula          DiaAula?
  horario          String?  @db.VarChar(4) // Ex: "14:30" - Bloqueio contra injeção de texto
  capacidadeMaxima Int?     @db.SmallInt

  escolaId String
  escola   Escola @relation(fields: [escolaId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  alunos AlunoAtividadeExtra[]

  @@index([escolaId])
  @@map("atividades_extra")
}

enum DiaAula {
  SEGUNDA
  TERCA
  QUARTA
  QUINTA
  SEXTA
  SABADO
  DOMINGO
  TODOS
}

// Tabela intermediária N:N
model AlunoAtividadeExtra {
  id String @id @default(uuid())

  alunoId String
  aluno   Aluno  @relation(fields: [alunoId], references: [id], onDelete: Cascade)

  atividadeExtraId String
  atividadeExtra   AtividadeExtra @relation(fields: [atividadeExtraId], references: [id], onDelete: Cascade)

  // A PROTEÇÃO DA EXTENSÃO (Obrigatório)
  escolaId String
  escola   Escola @relation(fields: [escolaId], references: [id], onDelete: Cascade)

  dataInicio DateTime  @default(now())
  dataFim    DateTime?
  ativo      Boolean   @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([alunoId, atividadeExtraId, escolaId]) // Isolamento total
  @@index([alunoId])
  @@index([atividadeExtraId])
  @@index([escolaId])
  @@map("alunos_atividades_extra")
}

// ============================================
// 8. BOLETOS (Livro de Recebíveis)
// ============================================
model Boletos {
  id String @id @default(uuid())

  // Identificação
  referencia    String @db.VarChar(50) // Ex: "Janeiro/2026"
  mesReferencia Int    @db.SmallInt
  anoReferencia Int    @db.SmallInt

  // Valores (A precisão Decimal 10,2 é inviolável)
  valorBase       Decimal  @db.Decimal(10, 2)
  valorAtividades Decimal  @default(0) @db.Decimal(10, 2)
  valorTotal      Decimal  @db.Decimal(10, 2)
  valorPago       Decimal? @db.Decimal(10, 2)

  // Datas
  dataVencimento DateTime  @db.Date
  dataPagamento  DateTime? @db.Date

  // Status
  status StatusPagamento @default(PENDENTE)

  // Informações adicionais
  formaPagamento FormaPagamento?
  comprovante    String?         @db.VarChar(500) // Aumentado para suportar URLs assinadas longas (S3/CloudFront)
  observacoes    String?         @db.VarChar(500)
  descricao      String?         @db.VarChar(255)

  // Integração Asaas
  asaasId   String? @unique @db.VarChar(100)
  boletoUrl String? @db.VarChar(500)
  pixQrCode String? @db.Text // Text é melhor para QR Code Base64 longo

  // Relacionamentos
  alunoId String
  aluno   Aluno  @relation(fields: [alunoId], references: [id], onDelete: Cascade)

  transacaoId String?    @unique
  transacao   Transacao? @relation(fields: [transacaoId], references: [id], onDelete: SetNull)

  escolaId String
  escola   Escola @relation(fields: [escolaId], references: [id], onDelete: Cascade)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([alunoId, referencia, escolaId]) // Impede a geração de boletos duplicados para o mesmo aluno/período
  @@index([escolaId]) // Index obrigatório para Multi-tenant
  @@index([alunoId])
  @@index([status])
  @@index([dataVencimento])
  @@map("boletos")
}

enum FormaPagamento {
  DINHEIRO
  PIX
  CARTAO
  BOLETO
  TRANSFERENCIA
}

enum StatusPagamento {
  PENDENTE
  PAGO
  VENCIDO
  CANCELADO
}

// ============================================
// 9. TRANSAÇÃO (Financeiro Unificado)
// ============================================
model Transacao {
  id String @id @default(uuid())

  tipo   TipoTransacao
  motivo String        @db.VarChar(100) // Ex: "Mensalidade - Janeiro", "Salário - Profª Maria"
  valor  Decimal       @db.Decimal(10, 2)
  data   DateTime      @default(now())

  observacao String? @db.VarChar(255)

  // Relacionamentos
  escolaId String
  escola   Escola @relation(fields: [escolaId], references: [id], onDelete: Cascade)

  responsavelId String? // Se for pagamento de mensalidade
  responsavel   Responsavel? @relation(fields: [responsavelId], references: [id], onDelete: SetNull)

  funcionarioId String? // Se for pagamento de salário
  funcionario   Funcionario? @relation(fields: [funcionarioId], references: [id], onDelete: SetNull)

  contratoId String? // ID da chave estrangeira
  contrato   Contrato? @relation(fields: [contratoId], references: [id])

  // Soft delete (importante para auditoria)
  deletedAt DateTime? @db.Date

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relacionamentos
  boletos        Boletos? // Relacionamento reverso
  histories      History[]
  formaPagamento FormaPagamento @default(DINHEIRO)

  @@index([escolaId])
  @@index([tipo])
  @@index([data])
  @@index([deletedAt])
  @@map("transacoes")
}

enum TipoTransacao {
  ENTRADA // Mensalidade, matrícula, extra
  SAIDA // Salário, contas, despesas
}

// ============================================
// 10. HISTORY (Auditoria de Transações)
// ============================================
model History {
  id String @id @default(uuid())

  tabela     String // "transacoes"
  registroId String // ID da transação
  acao       AcaoHistory // CREATE, UPDATE, DELETE

  dadosAntes  Json? // Estado anterior (JSON)
  dadosDepois Json? // Estado posterior (JSON)

  // Quem fez
  usuarioId String
  usuario   Usuario @relation(fields: [usuarioId], references: [id], onDelete: Restrict)

  // Relacionamento opcional com transação
  transacaoId String?
  transacao   Transacao? @relation(fields: [transacaoId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([tabela, registroId])
  @@index([usuarioId])
  @@index([createdAt])
  @@map("histories")
}

enum AcaoHistory {
  CREATE
  UPDATE
  DELETE
  ESTORNO
}

// ============================================
// 11. TURMA (Coração Pedagógico)
// ============================================
model Turma {
  id               String @id @default(uuid())
  nome             String @db.VarChar(100) // Limite de segurança
  turno            Turno
  anoLetivo        Int    @db.SmallInt
  capacidadeMaxima Int    @default(30)

  // Isolamento Multi-tenant
  escolaId String
  escola   Escola @relation(fields: [escolaId], references: [id], onDelete: Cascade)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime? @db.Date

  // Suporte ao Soft Delete

  // Relacionamentos omitidos para brevidade...
  alunos           Aluno[]
  turmaProfessors  TurmaProfessor[]
  turmaDisciplinas TurmaDisciplina[]
  notas            Nota[]
  frequencias      Frequencia[]
  comunicados      Comunicado[]
  matriculas       Matricula[]
  eventos          Evento[]
  gradeHorarias    GradeHoraria[]
  cronogramaProva  CronogramaProva[]

  // TRAVA DE INTEGRIDADE: Impede a criação de turmas duplicadas no mesmo ano/turno
  @@unique([nome, anoLetivo, turno, escolaId])
  @@index([escolaId])
  @@index([anoLetivo])
  @@index([deletedAt]) // Fundamental para queries com soft delete
  @@map("turmas")
}

enum Turno {
  MANHA
  TARDE
  NOITE
  INTEGRAL
}

// ============================================
// 12. PROFESSOR/FUNCIONÁRIO
// ============================================
model Funcionario {
  id             String    @id @default(uuid())
  nome           String    @db.VarChar(100)
  cpf            String    @db.VarChar(11) // REMOVIDO @unique global
  rg             String?   @db.VarChar(20)
  dataNascimento DateTime?
  telefone       String?   @db.VarChar(15)
  email          String?   @db.VarChar(100)
  foto           String?   @db.VarChar(255)

  cargo             CargoFuncionario
  dataAdmissao      DateTime          @default(now())
  dataDemissao      DateTime?
  salarioBase       Decimal           @db.Decimal(10, 2)
  statusFuncionario StatusFuncionario @default(ATIVO)

  escolaId   String
  escola     Escola    @relation(fields: [escolaId], references: [id], onDelete: Cascade)
  enderecoId String?
  endereco   Endereco? @relation(fields: [enderecoId], references: [id], onDelete: SetNull)

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // Relacionamentos
  turmas                TurmaProfessor[]
  transacoes            Transacao[] // Pagamentos de salário
  ocorrencias           Ocorrencia[]
  disciplinasLecionadas TurmaDisciplina[]
  lancamentos           Lancamento[]
  pagamentoSalarios     PagamentoSalario[]
  dadosBancarios        DadosBancarios?

  @@unique([cpf, escolaId]) // A PROTEÇÃO MULTI-TENANT
  @@index([escolaId])
  @@index([cargo])
  @@index([deletedAt])
  @@map("funcionarios")
}

enum CargoFuncionario {
  PROFESSOR
  COORDENADOR
  SECRETARIA
  DIRETOR
  AUXILIAR
  OUTRO
}

enum StatusFuncionario {
  ATIVO
  AFASTADO
  DEMITIDO
  APOSENTADO
}

model PagamentoSalario {
  id String @id @default(uuid())

  // Referência Temporal 
  mesReferencia Int
  anoReferencia Int

  // Valores do Mês 
  salarioBase       Decimal @db.Decimal(10, 2)
  salarioAcrescimos Decimal @default(0) @db.Decimal(10, 2)
  salarioDesconto   Decimal @default(0) @db.Decimal(10, 2)
  valorLiquido      Decimal @db.Decimal(10, 2) // Calculado: Base + Acrescimos - Descontos
  observacoes       String?

  // Dados de Pagamento
  dataPagamento  DateTime        @default(now())
  formaPagamento String
  status         StatusPagamento @default(PAGO)

  // Relacionamentos e Isolamento
  funcionarioId String
  funcionario   Funcionario @relation(fields: [funcionarioId], references: [id])

  escolaId String
  escola   Escola @relation(fields: [escolaId], references: [id], onDelete: Cascade)

  // O Vínculo com o Caixa Geral
  lancamentoId String?     @unique
  lancamento   Lancamento? @relation(fields: [lancamentoId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([escolaId])
  @@index([funcionarioId])
  @@index([mesReferencia, anoReferencia])
  @@map("pagamentos_salarios")
}

// Tabela intermediária 1:1 Dados bancários do funcionário
model DadosBancarios {
  id            String    @id @default(uuid())
  banco         String?   @db.VarChar(50)
  agencia       String?   @db.VarChar(10)
  agenciaDigito String?   @db.VarChar(2)
  conta         String?   @db.VarChar(20)
  contaDigito   String?   @db.VarChar(2)
  tipoConta     TipoConta @default(CORRENTE)

  tipoChavePix TipoChavePix?
  chavePix     String?       @db.VarChar(100)

  funcionarioId String      @unique
  funcionario   Funcionario @relation(fields: [funcionarioId], references: [id], onDelete: Cascade)

  escolaId  String
  updatedAt DateTime @updatedAt

  @@index([escolaId])
  @@map("dados_bancarios_funcionarios")
}

enum TipoConta {
  CORRENTE
  POUPANCA
  SALARIO
  PAGAMENTO
}

enum TipoChavePix {
  CPF
  CNPJ
  EMAIL
  TELEFONE
  ALEATORIA
}

// Tabela intermediária N:N (Turma - Professor)
model TurmaProfessor {
  id          String      @id @default(uuid())
  turmaId     String
  turma       Turma       @relation(fields: [turmaId], references: [id], onDelete: Cascade)
  professorId String
  professor   Funcionario @relation(fields: [professorId], references: [id], onDelete: Cascade)
  isPrincipal Boolean     @default(true)

  // A PROTEÇÃO DA EXTENSÃO (Obrigatório)
  escolaId String
  escola   Escola @relation(fields: [escolaId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([turmaId, professorId, escolaId]) // Isolamento Total
  @@index([turmaId])
  @@index([professorId])
  @@index([escolaId])
  @@map("turmas_professores")
}

// ============================================
// 13. DISCIPLINA
// ============================================
model Disciplina {
  id           String  @id @default(uuid())
  nome         String // Ex: "Matemática", "Português"
  descricao    String?
  cargaHoraria Int? // Horas por semana

  escolaId String
  escola   Escola @relation(fields: [escolaId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relacionamentos
  turmas          TurmaDisciplina[]
  notas           Nota[]
  frequencias     Frequencia[]
  cronogramaProva CronogramaProva[]

  @@index([escolaId])
  @@map("disciplinas")
}

// Tabela intermediária N:N (Turma - Disciplina)
model TurmaDisciplina {
  id String @id @default(uuid())

  turmaId String
  turma   Turma  @relation(fields: [turmaId], references: [id], onDelete: Cascade)

  disciplinaId String
  disciplina   Disciplina @relation(fields: [disciplinaId], references: [id], onDelete: Cascade)

  professorId String
  professor   Funcionario @relation(fields: [professorId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  horarios GradeHoraria[]

  @@unique([turmaId, disciplinaId])
  @@index([turmaId])
  @@index([disciplinaId])
  @@map("turmas_disciplinas")
}

// ============================================
// 14. NOTA (4 Bimestres)
// ============================================
model Nota {
  id String @id @default(uuid())

  // Identificação
  bimestre  Int // 1, 2, 3 ou 4
  anoLetivo Int // Ex: 2026

  // Nota
  valor Decimal @db.Decimal(4, 2) // Ex: 8.50

  // Observações do professor
  observacao String?

  // Relacionamentos
  alunoId String
  aluno   Aluno  @relation(fields: [alunoId], references: [id], onDelete: Cascade)

  turmaId String
  turma   Turma  @relation(fields: [turmaId], references: [id], onDelete: Cascade)

  disciplinaId String
  disciplina   Disciplina @relation(fields: [disciplinaId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Um aluno não pode ter 2 notas no mesmo bimestre/disciplina
  @@unique([alunoId, disciplinaId, bimestre, anoLetivo])
  @@index([alunoId])
  @@index([turmaId])
  @@index([disciplinaId])
  @@map("notas")
}

// ============================================
// 15. FREQÜÊNCIA
// ============================================

model Frequencia {
  id String @id @default(uuid())

  data          DateTime @default(now())
  presente      Boolean  @default(true)
  justificativa String?

  alunoId String
  aluno   Aluno  @relation(fields: [alunoId], references: [id], onDelete: Cascade)

  turmaId String
  turma   Turma  @relation(fields: [turmaId], references: [id], onDelete: Cascade)

  disciplinaId String?
  disciplina   Disciplina? @relation(fields: [disciplinaId], references: [id], onDelete: SetNull)

  escolaId String
  escola   Escola @relation(fields: [escolaId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([alunoId, turmaId, data, disciplinaId])
  @@index([alunoId])
  @@index([turmaId])
  @@index([escolaId])
  @@index([data])
  @@map("frequencias")
}

// ============================================
// 16. COMUNICADO
// ============================================

model Comunicado {
  id String @id @default(uuid())

  titulo        String
  mensagem      String
  tipo          TipoComunicado       @default(GERAL)
  prioridade    PrioridadeComunicado @default(NORMAL)
  destinatarios String               @default("TODOS")
  dataEnvio     DateTime             @default(now())
  lido          Boolean              @default(false)

  escolaId String
  escola   Escola @relation(fields: [escolaId], references: [id], onDelete: Cascade)

  alunoId String?
  aluno   Aluno?  @relation(fields: [alunoId], references: [id], onDelete: Cascade)

  turmaId String?
  turma   Turma?  @relation(fields: [turmaId], references: [id], onDelete: SetNull)

  responsavelId String?
  responsavel   Responsavel? @relation(fields: [responsavelId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([escolaId])
  @@index([alunoId])
  @@index([turmaId])
  @@index([responsavelId])
  @@map("comunicados")
}

enum TipoComunicado {
  GERAL
  FINANCEIRO
  PEDAGOGICO
  EVENTO
  URGENTE
}

enum PrioridadeComunicado {
  BAIXA
  NORMAL
  ALTA
  URGENTE
}

enum Destinatarios {
  TODOS
  TURMA
  INADIMPLENTES
}

// ============================================
// 17. MATRICULA
// ============================================

model Matricula {
  id String @id @default(uuid())

  // Dados principais
  numeroMatricula String          @unique
  dataMatricula   DateTime        @default(now())
  anoLetivo       Int
  status          StatusMatricula @default(EM_ANDAMENTO)

  // Etapas do processo
  etapaAtual          EtapaMatricula @default(DADOS_PESSOAIS)
  dadosPessoaisOk     Boolean        @default(false)
  documentosOk        Boolean        @default(false)
  responsaveisOk      Boolean        @default(false)
  contratoAssinado    Boolean        @default(false)
  pagamentoConfirmado Boolean        @default(false)

  // Relacionamentos
  alunoId String @unique
  aluno   Aluno  @relation(fields: [alunoId], references: [id], onDelete: Cascade)

  turmaId String
  turma   Turma  @relation(fields: [turmaId], references: [id], onDelete: Restrict)

  escolaId String
  escola   Escola @relation(fields: [escolaId], references: [id], onDelete: Cascade)

  contratoId String? // Gerado ao final da matrícula
  contrato   Contrato? @relation(fields: [contratoId], references: [id], onDelete: SetNull)

  // Observações
  observacoes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([escolaId])
  @@index([status])
  @@index([anoLetivo])
  @@map("matriculas")
}

enum StatusMatricula {
  PENDENTE
  EM_ANDAMENTO
  APROVADA
  REJEITADA
  CANCELADA
}

enum EtapaMatricula {
  DADOS_PESSOAIS
  DOCUMENTOS
  RESPONSAVEIS
  CONTRATO
  PAGAMENTO
  FINALIZADA
}

// ============================================
// 18. REMATRICULA
// ============================================

model Rematricula {
  id String @id @default(uuid())

  anoAnterior Int
  anoNovo     Int
  status      StatusRematricula @default(PENDENTE)

  // Mudanças
  turmaAnteriorId String
  turmaNova       String?

  valorAnterior Decimal @db.Decimal(10, 2)
  valorNovo     Decimal @db.Decimal(10, 2)

  // Relacionamentos
  alunoId String
  aluno   Aluno  @relation(fields: [alunoId], references: [id], onDelete: Cascade)

  escolaId String
  escola   Escola @relation(fields: [escolaId], references: [id], onDelete: Cascade)

  dataConfirmacao DateTime?
  observacoes     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([escolaId])
  @@index([status])
  @@index([anoNovo])
  @@map("rematriculas")
}

enum StatusRematricula {
  PENDENTE
  CONFIRMADA
  RECUSADA
  CANCELADA
}

// ============================================
// 19. OCORRENCIA
// ============================================

model Ocorrencia {
  id String @id @default(uuid())

  titulo    String
  descricao String
  tipo      TipoOcorrencia
  gravidade GravidadeOcorrencia @default(LEVE)
  data      DateTime            @default(now())

  // Ações tomadas
  acaoTomada      String?
  responsavelAcao String?

  // Comunicado aos pais
  paisComunicados Boolean   @default(false)
  dataComunicacao DateTime?

  // Relacionamentos
  alunoId String
  aluno   Aluno  @relation(fields: [alunoId], references: [id], onDelete: Cascade)

  funcionarioId String
  funcionario   Funcionario @relation(fields: [funcionarioId], references: [id], onDelete: Restrict)

  escolaId String
  escola   Escola @relation(fields: [escolaId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([escolaId])
  @@index([alunoId])
  @@index([tipo])
  @@index([data])
  @@map("ocorrencias")
}

enum TipoOcorrencia {
  COMPORTAMENTO
  FALTA_DISCIPLINAR
  BULLYING
  ATRASO
  UNIFORME
  MATERIAL
  OUTROS
}

enum GravidadeOcorrencia {
  LEVE
  MODERADA
  GRAVE
  GRAVISSIMA
}

// ============================================
// 20. EVENTO
// ============================================

model Evento {
  id String @id @default(uuid())

  titulo     String
  descricao  String?
  tipo       TipoEvento
  dataInicio DateTime
  dataFim    DateTime?
  horaInicio String? // "08:00"
  horaFim    String? // "12:00"

  // Configurações
  diaLetivo Boolean @default(true)
  publico   Boolean @default(true) // Visível para pais

  // Relacionamentos
  escolaId String
  escola   Escola @relation(fields: [escolaId], references: [id], onDelete: Cascade)

  turmaId String? // Evento específico de uma turma
  turma   Turma?  @relation(fields: [turmaId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([escolaId])
  @@index([dataInicio])
  @@index([tipo])
  @@map("eventos")
}

enum TipoEvento {
  AULA
  PROVA
  REUNIAO
  FERIADO
  EVENTO_ESCOLAR
  RECESSO
  FERIAS
  OUTROS
}

// ============================================
// 21. LOG AUDITORIA (Trilha Forense)
// ============================================
model LogAuditoria {
  id         String @id @default(uuid())
  entidade   String @db.VarChar(100)
  entidadeId String @db.VarChar(100)
  acao       String @db.VarChar(100)

  // JSONs mantidos, pois registram snapshots dinâmicos
  dadosAntigos Json? @db.Json
  dadosNovos   Json? @db.Json

  usuarioId String? @db.VarChar(36) // Não fazemos FK direta para manter o log mesmo se o user for deletado

  escolaId String
  escola   Escola @relation(fields: [escolaId], references: [id], onDelete: Cascade)

  ip        String?  @db.VarChar(45) // Suporte para IPv6 longo
  createdAt DateTime @default(now())

  @@index([escolaId])
  @@index([entidade])
  @@index([createdAt])
  @@map("logs_auditoria")
}

// ============================================
// 22. LANÇAMENTOS (Gestão de Entradas e Saídas Avulsas)
// ============================================
model Lancamento {
  id        String        @id @default(uuid())
  descricao String        @db.VarChar(255) // TRAVA DE SEGURANÇA
  tipo      TipoTransacao // ENTRADA ou SAIDA
  categoria String        @db.VarChar(100) // TRAVA DE SEGURANÇA
  valor     Decimal       @db.Decimal(10, 2)

  dataVencimento DateTime        @db.Date
  dataLiquidacao DateTime?       @db.Date
  status         StatusPagamento @default(PENDENTE)

  // O Isolamento
  escolaId String
  escola   Escola @relation(fields: [escolaId], references: [id], onDelete: Cascade)

  // Vínculos Opcionais
  alunoId       String?
  aluno         Aluno?       @relation(fields: [alunoId], references: [id], onDelete: SetNull)
  funcionarioId String?
  funcionario   Funcionario? @relation(fields: [funcionarioId], references: [id], onDelete: SetNull)
  responsavelId String?
  responsavel   Responsavel? @relation(fields: [responsavelId], references: [id], onDelete: SetNull)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  pagamentoSalario PagamentoSalario?

  @@index([escolaId])
  @@index([tipo])
  @@index([status])
  @@index([dataVencimento]) // Index vital para dashboards financeiros
  @@map("lancamentos")
}

// ============================================
// 23. Grade Horária
// ============================================

model GradeHoraria {
  id            String @id @default(uuid())
  diaSemana     Int // 1 (Segunda) a 5 (Sexta) ou 6 (Sábado)
  horarioInicio String // Ex: "07:30"
  horarioFim    String // Ex: "08:20"

  // Conecta com o vínculo que você já criou (Turma + Disciplina + Professor)
  turmaDisciplinaId String
  turmaDisciplina   TurmaDisciplina @relation(fields: [turmaDisciplinaId], references: [id], onDelete: Cascade)

  turmaId String
  turma   Turma  @relation(fields: [turmaId], references: [id], onDelete: Cascade)

  escolaId String
  escola   Escola @relation(fields: [escolaId], references: [id], onDelete: Cascade)

  @@index([escolaId])
  @@index([turmaDisciplinaId])
  @@index([turmaId])
  @@map("grades_horarias")
}

// ============================================
// 23. Cronograma de provas
// ============================================

model CronogramaProva {
  id    String   @id @default(uuid())
  data  DateTime
  ordem Int      @default(1) // 1ª prova do dia, 2ª prova do dia

  turmaId String
  turma   Turma  @relation(fields: [turmaId], references: [id], onDelete: Cascade)

  disciplinaId String
  disciplina   Disciplina @relation(fields: [disciplinaId], references: [id], onDelete: Cascade)

  escolaId String
  escola   Escola @relation(fields: [escolaId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([turmaId])
  @@index([escolaId])
  @@map("cronogramas_provas")
}
